exports[`snippet: tests-config/debug/linenumbers.less format 1`] = `
====================================options=====================================
parsers: ["less"]
                                                      printWidth: 80 (default) |
=====================================input======================================
@charset "UTF-8";

@import "import/test.less";

.start() {
  .test-rule2 {
      color: red;
  }
}

.mix() {
    color: black;
}

.test-rule1 {
  .mix();
}

.start();

.mixin_import1();

.mixin_import2();

@debug: 1;
& when (@debug = 1) {
  .test-rule {
    color: red;
    & when (@debug = 1) {
      width: 2;
    }
  }
}

.supports-rule {
  @supports (display: grid) {
    color: green;
    .nested-supports {
      color: blue;
    }
  }
}
=====================================output=====================================
@charset "UTF-8";

@import "import/test.less";

.start() {
  .test-rule2 {
    color: red;
  }
}

.mix() {
  color: black;
}

.test-rule1 {
  .mix();
}

.start();

.mixin_import1();

.mixin_import2();

@debug: 1;
& when (@debug = 1) {
  .test-rule {
    color: red;
    & when (@debug = 1) {
      width: 2;
    }
  }
}

.supports-rule {
