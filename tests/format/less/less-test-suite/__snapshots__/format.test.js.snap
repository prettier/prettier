exports[`snippet: tests-unit/mixins-important/mixins-important.less format 1`] = `
====================================options=====================================
parsers: ["less"]
                                                      printWidth: 80 (default) |
=====================================input======================================
.submixin(@a) {
  border-width: @a;
}
.mixin (9) {
  border: 9 !important;
}
.mixin (@a: 0) {
  border: @a;
  boxer: @a;
  .inner {
    test: @a;
  }
  // comment
  .submixin(@a);
}

.class {
  .mixin(1);
  .mixin(2) !important;
  .mixin(3);
  .mixin(4) !important;
  .mixin(5);
  .mixin() !important;
  .mixin(9);
}
.size(@aaa: auto) {
  .set-width(@aaa) {
    width: @aaa;
  }
  .set-width(@aaa);
}
.when-calling-nested-issue-2394 {
  .size() !important;
}
.when-calling-nested-with-param-issue-2394 {
  .size(10px) !important;
}
.test-ruleMixin-2421 () {
    .topCheck-2421 () {
        .nestedCheck-2421() {
            margin: 5px;
        }
        .nestedCheck-2421();
    }
    .topCheck-2421();
}
.class1-2421 {
    .test-ruleMixin-2421() !important;
}
.class2-2421 {
    .test-ruleMixin-2421();
}

=====================================output=====================================
.submixin(@a) {
  border-width: @a;
}
.mixin (9) {
  border: 9 !important;
}
.mixin (@a: 0) {
  border: @a;
  boxer: @a;
  .inner {
    test: @a;
  }
  // comment
  .submixin(@a);
}

.class {
  .mixin(1);
  .mixin(2) !important;
  .mixin(3);
  .mixin(4) !important;
  .mixin(5);
  .mixin() !important;
  .mixin(9);
}
.size(@aaa: auto) {
  .set-width(@aaa) {
    width: @aaa;
  }
  .set-width(@aaa);
}
.when-calling-nested-issue-2394 {
  .size() !important;
}
.when-calling-nested-with-param-issue-2394 {
  .size(10px) !important;
}
.test-ruleMixin-2421 () {
  .topCheck-2421 () {
    .nestedCheck-2421() {
      margin: 5px;
    }
    .nestedCheck-2421();
  }
  .topCheck-2421();
}
.class1-2421 {
  .test-ruleMixin-2421() !important;
}
.class2-2421 {
  .test-ruleMixin-2421();
}

================================================================================
`;

exports[`snippet: tests-unit/mixins-named-args/mixins-named-args.less format 1`] = `
====================================options=====================================
parsers: ["less"]
                                                      printWidth: 80 (default) |
=====================================input======================================
.mixin (@a: 1px, @b: 50%) {
  width: (@a * 5);
  height: (@b - 1%);
  args: @arguments;
}
.mixin (@a: 1px, @b: 50%) when (@b > 75%){
  text-align: center;
}

.named-arg {
  color: blue;
  .mixin(@b: 100%);
}

.class {
  @var: 20%;
  .mixin(@b: @var);
}

.all-args-wrong-args {
  .mixin(@b: 10%, @a: 2px);
}

.mixin2 (@a: 1px, @b: 50%, @c: 50) {
  width: (@a * 5);
  height: (@b - 1%);
  color: (#000000 + @c);
}

.named-args2 {
  .mixin2(3px, @c: 100);
}

.named-args3 {
  .mixin2(@b: 30%, @c: #123456);
}

=====================================output=====================================
.mixin (@a: 1px, @b: 50%) {
