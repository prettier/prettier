  .mixin-takes-one(i);
  .mixin-takes-one(j;);
  .mixin-takes-two(k, l);
  .mixin-takes-one(m, n;);
  .mixin-takes-two(o, p; q);
  .mixin-takes-two(r, s; t;);
}

.mixin-conflict(@a:defA, @b:defB, @c:defC) {
  three: @a, @b, @c;
}

.mixin-conflict(@a:defA, @b:defB, @c:defC, @d:defD) {
  four: @a, @b, @c, @d;
}

#named-conflict {
