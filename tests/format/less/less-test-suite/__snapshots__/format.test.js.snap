  .mixin(@b: 10%, @a: 2px);
}

.mixin2 (@a: 1px, @b: 50%, @c: 50) {
  width: (@a * 5);
  height: (@b - 1%);
  color: (#000000 + @c);
}

.named-args2 {
  .mixin2(3px, @c: 100);
}

.named-args3 {
  .mixin2(@b: 30%, @c: #123456);
}

================================================================================
`;

exports[`snippet: tests-unit/mixins-nested/mixins-nested.less format 1`] = `
====================================options=====================================
parsers: ["less"]
                                                      printWidth: 80 (default) |
=====================================input======================================
.mix-inner (@var) {
  border-width: @var;
}

.mix (@a: 10) {
  .inner {
    height: (@a * 10);

    .innest {
      width: @a;
      .mix-inner((@a * 2));
    }
  }
}

.class {
  .mix(30);
}

.class2 {
  .mix(60);
}

=====================================output=====================================
.mix-inner (@var) {
  border-width: @var;
}

.mix (@a: 10) {
  .inner {
    height: (@a * 10);

    .innest {
      width: @a;
      .mix-inner((@a * 2));
    }
  }
}

.class {
  .mix(30);
}

.class2 {
  .mix(60);
}

