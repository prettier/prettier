exports[`snippet: tests-config/namespacing/namespacing-functions.less format 1`] = `
====================================options=====================================
parsers: ["less"]
                                                      printWidth: 80 (default) |
=====================================input======================================
.add(@a, @b) {
  @r: @a + @b;
}
.foo {
  width: .add(10px, 10px)[];
  bar: @return[];
}

@return: {
  single: val;
}

// Issue #3405
#lookup {
  @prop: test;
}

.mix (@var) {
  width: @var;
}

.bar {
  .mix(#lookup[@prop]);
}

// Issue #3406
.mix2 (@n) {
  value: @n;
}
#lookup2 {
  @var: .mix2(lookup);
}
.example {
  // #lookup[@var](); -- fails, need the following alias
  @dr: #lookup2[@var];
  @dr();
}
=====================================output=====================================
.add(@a, @b) {
  @r: @a + @b;
}
.foo {
  width: .add(10px, 10px) [];
  bar: @return[];
}

@return: {
  single: val;
};

// Issue #3405
#lookup {
  @prop: test;
}

.mix (@var) {
  width: @var;
}

.bar {
  .mix(#lookup[@prop]);
}

// Issue #3406
.mix2 (@n) {
  value: @n;
}
#lookup2 {
  @var: .mix2(lookup);
}
.example {
  // #lookup[@var](); -- fails, need the following alias
  @dr: #lookup2[ @var];
  @dr();
}

================================================================================
`;

exports[`snippet: tests-config/namespacing/namespacing-media.less format 1`] = `
====================================options=====================================
parsers: ["less"]
                                                      printWidth: 80 (default) |
=====================================input======================================
#ns {
  .sizes() {
    @small: 600px;
  }
  .breakpoint(@size) {
    @val: #ns.sizes[@@size];
    @min: (min-width: @val);
    @max: not all and @min;
  }
}

#ns {
  .sizes() {
    @small: 480px;
  }
}

.valToGet() {
  keyword: small;
}

@media #ns.breakpoint(.valToGet[])[@max] {
  .selector {
    prop: val;
  }
}
=====================================output=====================================
#ns {
  .sizes() {
    @small: 600px;
  }
  .breakpoint(@size) {
    @val: #ns.sizes[ @@size];
    @min: (min-width: @val);
    @max: not all and @min;
  }
}

#ns {
  .sizes() {
    @small: 480px;
  }
}

.valToGet() {
  keyword: small;
}

@media #ns.breakpoint(.valToGet[]) [@max] {
  .selector {
    prop: val;
  }
}

================================================================================
`;

