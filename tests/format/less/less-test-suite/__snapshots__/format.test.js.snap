exports[`snippet: tests-config/strict-imports/strict-imports.less format 1`] = `
====================================options=====================================
parsers: ["less"]
                                                      printWidth: 80 (default) |
=====================================input======================================
// Test that strictImports: true allows @import at root level
@import "imported.less";

// Test that strictImports: true allows @import inside @media blocks
@media (max-width: 768px) {
  @import "imported.less";
  .mobile {
    color: red;
  }
}

// Test that strictImports: true skips @import inside selector blocks (import is not processed)
.container {
  @import "imported.less";
  .nested {
    color: blue;
  }
}


=====================================output=====================================
// Test that strictImports: true allows @import at root level
@import "imported.less";

// Test that strictImports: true allows @import inside @media blocks
@media (max-width: 768px) {
  @import "imported.less";
  .mobile {
    color: red;
  }
}

// Test that strictImports: true skips @import inside selector blocks (import is not processed)
.container {
  @import "imported.less";
  .nested {
    color: blue;
  }
}

================================================================================
`;

