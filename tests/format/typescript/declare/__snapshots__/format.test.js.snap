// Jest Snapshot v1, https://jestjs.io/docs/snapshot-testing

exports[`declare-class-fields.ts format 1`] = `
====================================options=====================================
parsers: ["typescript"]
                                                      printWidth: 80 (default) |
=====================================input======================================
class B {p: number;}
class C extends B {declare p: 256 | 1000;}
class D {
  declare field = "field";
}
declare class D {
  field = "field";
}

=====================================output=====================================
class B {
  p: number;
}
class C extends B {
  declare p: 256 | 1000;
}
class D {
  declare field = "field";
}
declare class D {
  field = "field";
}

================================================================================
`;

exports[`declare-class-fields.ts format[babel-ts] 1`] = `
"Initializers are not allowed in ambient contexts. (4:17)
  2 | class C extends B {declare p: 256 | 1000;}
  3 | class D {
> 4 |   declare field = "field";
    |                 ^
  5 | }
  6 | declare class D {
  7 |   field = "field";
Cause: Initializers are not allowed in ambient contexts. (4:16)"
`;

exports[`declare-class-fields.ts format[oxc-ts] 1`] = `
"Initializers are not allowed in ambient contexts. (4:19)
  2 | class C extends B {declare p: 256 | 1000;}
  3 | class D {
> 4 |   declare field = "field";
    |                   ^^^^^^^
  5 | }
  6 | declare class D {
  7 |   field = "field";"
`;

