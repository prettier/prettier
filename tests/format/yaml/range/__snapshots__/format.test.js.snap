// Jest Snapshot v1, https://jestjs.io/docs/snapshot-testing

exports[`anchors-aliases.yml format 1`] = `
    : ====================================options=====================================
    : parsers: ["yaml"]
    : rangeEnd: 29
    : rangeStart: 13
    :                                                       printWidth: 80 (default) |
    : =====================================input======================================
> 1 | a: &anchor   value
    |              ^^^^^
> 2 | b: *anchor
    | ^^^^^^^^^^
  3 |
    : =====================================output=====================================
    : a: &anchor value
    : b: *anchor
    : ================================================================================
`;

exports[`basic.yml format 1`] = `
    : ====================================options=====================================
    : parsers: ["yaml"]
    : rangeEnd: 22
    : rangeStart: 10
    :                                                       printWidth: 80 (default) |
    : =====================================input======================================
  1 | a:      1
> 2 | b:  2
    | ^^^^^
> 3 | c:   3
    | ^^^^^^
  4 | d:      4
  5 |
    : =====================================output=====================================
    : a:      1
    : b: 2
    : c: 3
    : d:      4
    :
    : ================================================================================
`;

exports[`block-folded.yml format 1`] = `
    : ====================================options=====================================
    : parsers: ["yaml"]
    : rangeEnd: 30
    : rangeStart: 13
    :                                                       printWidth: 80 (default) |
    : =====================================input======================================
  1 | key: >2-
> 2 |     line 1
    |     ^^^^^^
> 3 |     line 2
    | ^^^^^^^^^^
  4 |
    : =====================================output=====================================
