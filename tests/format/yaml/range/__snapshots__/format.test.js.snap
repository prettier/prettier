    : ================================================================================
`;

exports[`comment-item.yml format 1`] = `
    : ====================================options=====================================
    : parsers: ["yaml"]
    : rangeEnd: 72
    : rangeStart: 5
    :                                                       printWidth: 80 (default) |
    : =====================================input======================================
  1 | foo:
> 2 |   # first we check this
    | ^^^^^^^^^^^^^^^^^^^^^^^
> 3 |   - condition: foobar
    | ^^^^^^^^^^^^^^^^^^^^^
> 4 |     output:      true
    | ^^^^^^^^^^^^^^^^^^^^^
  5 |
  6 |   # then we check that
  7 |   - condition: barbar
  8 |     output:      true
  9 |
    : =====================================output=====================================
    : foo:
    :   # first we check this
    :   - condition: foobar
    :     output: true
    :
    :   # then we check that
    :   - condition: barbar
    :     output: true
    : ================================================================================
`;

exports[`comments.yml format 1`] = `
    : ====================================options=====================================
    : parsers: ["yaml"]
    : rangeEnd: 84
    : rangeStart: 43
    :                                                       printWidth: 80 (default) |
    : =====================================input======================================
  1 | a:      1
  2 | # comment before b (should stay)
> 3 | b:      2
    | ^^^^^^^^^
> 4 | # comment after b (should stay)
    | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
  5 | c:      3
  6 |
    : =====================================output=====================================
    : a:      1
    : # comment before b (should stay)
    : b:      2
    : # comment after b (should stay)
    : c:      3
    :
    : ================================================================================
`;

exports[`complex-keys.yml format 1`] = `
    : ====================================options=====================================
    : parsers: ["yaml"]
    : rangeEnd: 19
    : rangeStart: 2
    :                                                       printWidth: 80 (default) |
    : =====================================input======================================
> 1 | ? - item1
    |   ^^^^^^^
> 2 |   - item2
    | ^^^^^^^^^
  3 | : value
  4 |
    : =====================================output=====================================
    : ? - item1
    :   - item2
    : : value
    :
    : ================================================================================
`;

