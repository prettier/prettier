exports[`like-import-declaration.mdx format 1`] = `
====================================options=====================================
parsers: ["mdx"]
                                                      printWidth: 80 (default) |
=====================================input======================================
<!-- These are not \`import\`s -->

import .meta.resolve (         foo)

import .meta; export {} from "./foo"

import .meta; import {} from "./foo"

import ("./foo")

import {} from   "./foo";            export {}

=====================================output=====================================
<!-- These are not \`import\`s -->

import .meta.resolve (         foo)

import .meta; export {} from "./foo"

import .meta; import {} from "./foo"

import ("./foo")

import {} from "./foo";
export {};

================================================================================
`;

