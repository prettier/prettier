// Jest Snapshot v1, https://jestjs.io/docs/snapshot-testing

exports[`attribute.mdx format 1`] = `
====================================options=====================================
parsers: ["mdx"]
                                                      printWidth: 80 (default) |
=====================================input======================================
<Foo foo={{color:     'red'}}></Foo>
<Foo foo={{
color:     'red'}}></Foo>
<Foo foo={{color:    /** @type {'red'} */('red')}}></Foo>

=====================================output=====================================
<Foo foo={{ color: "red" }}></Foo>
<Foo
  foo={{
    color: "red",
  }}
></Foo>
<Foo foo={{ color: /** @type {'red'} */ ("red") }}></Foo>

================================================================================
`;

exports[`spread.mdx format 1`] = `
====================================options=====================================
parsers: ["mdx"]
                                                      printWidth: 80 (default) |
=====================================input======================================
<C {...props} />

<C { ...props } />

<C {...props}>text</C>

<C {...a.b.c} />

<C {/* comment */ ...props} />

<C {...props // after
} />

<C {// before
...props} />

<C a="1" {...rest} b={2} />

a <b {...c} /> d

- item
  <C {...props} />

=====================================output=====================================
<C {...props} />

<C {...props} />

<C {...props}>text</C>

<C {...a.b.c} />

<C {/* comment */ ...props} />

<C
  {
    ...props // after
  }
/>

<C
  {
    // before
    ...props
  }
/>

<C a="1" {...rest} b={2} />

a <b {...c} /> d

- item
  <C {...props} />

================================================================================
`;
