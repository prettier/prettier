exports[`snippet: apollo-rs/parser/ok/0037_operation_type_definition_with_inline_fragment.graphql format 1`] = `
====================================options=====================================
parsers: ["graphql"]
                                                      printWidth: 80 (default) |
=====================================input======================================
query SomeQuery(
  $param1: String!
  $param2: String!
) {
  item1(
    param1: $param1
    param2: $param2
  ) {
    id
    ... on Fragment1 {
      field3 {
        field4
      }
    }
  }
}
=====================================output=====================================
query SomeQuery($param1: String!, $param2: String!) {
  item1(param1: $param1, param2: $param2) {
    id
    ... on Fragment1 {
      field3 {
        field4
      }
    }
  }
}

================================================================================
`;

exports[`snippet: apollo-rs/parser/ok/0038_wrapped_named_types.graphql format 1`] = `
