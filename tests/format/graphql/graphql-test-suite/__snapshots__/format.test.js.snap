  b: Int!
  c: [Int!]!
  d: [[[[[Int]]]]]
  d: [[[[[Int!]!]!]!]!]!
}

================================================================================
`;

exports[`snippet: apollo-rs/parser/ok/0039_variable_with_directives.graphql format 1`] = `
