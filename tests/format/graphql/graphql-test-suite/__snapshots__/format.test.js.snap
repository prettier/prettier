                                                      printWidth: 80 (default) |
=====================================input======================================
{
  ...friendFields
}

fragment friendFields on User {
  id
  name
}
=====================================output=====================================
{
  ...friendFields
}

fragment friendFields on User {
  id
  name
}

================================================================================
`;

