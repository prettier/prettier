exports[`example-2.md - {"proseWrap":"always"} format 1`] = `
====================================options=====================================
parsers: ["markdown"]
proseWrap: "always"
                                                      printWidth: 80 (default) |
=====================================input======================================
# linebreak after opening brace

{

---

# including empty lines

{{ foo

bar   baz

qux }}

---

# line break after %

{% foo %

bar  baz %}

=====================================output=====================================
# linebreak after opening brace

{

---

# including empty lines

{{ foo

bar baz

qux }}

---

# line break after %

{% foo %

bar baz %}

================================================================================
`;

