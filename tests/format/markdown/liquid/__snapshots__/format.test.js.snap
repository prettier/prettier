exports[`issue-19488.md - {"proseWrap":"always"} format 1`] = `
====================================options=====================================
parsers: ["markdown"]
proseWrap: "always"
                                                      printWidth: 80 (default) |
=====================================input======================================
{{% blocks/cover
title="Welcome"
%}}

This input uses Hugo shortcode. Prettier doesn't support this explicitly but it shouldn't break it either.

{{% /blocks/cover %}}

=====================================output=====================================
{{% blocks/cover
title="Welcome"
%}}

This input uses Hugo shortcode. Prettier doesn't support this explicitly but it
shouldn't break it either.

{{% /blocks/cover %}}

================================================================================
`;

