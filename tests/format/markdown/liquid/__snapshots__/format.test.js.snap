exports[`character-after-closing-tokens.md - {"proseWrap":"always"} format 1`] = `
====================================options=====================================
parsers: ["markdown"]
proseWrap: "always"
                                                      printWidth: 80 (default) |
=====================================input======================================
{{ page.title
}} a

---

{%
 if user
%} Hello, {{ user }}!
{% endif %}

=====================================output=====================================
{{ page.title
 a

---

{%
 if user
 Hello, {{ user }}! {% endif %}

================================================================================
`;

